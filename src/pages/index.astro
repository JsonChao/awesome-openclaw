---
import '../styles/tailwind.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

const lang = Astro.url.searchParams.get('lang') === 'zh' ? 'zh' : 'en';
const isZh = lang === 'zh';

const pageTitle = isZh
  ? 'awesome openclaw | ai openclaw 教程、技能与资源导航中心'
  : 'ai openclaw Guide | Skills, Tutorials, and Resources';
const pageDescription = isZh
  ? 'awesome openclaw 是面向 ai openclaw 的中文教程与资源导航站，覆盖安装、模型、技能、自动化、安全与成本优化，提供7天学习路径与精选资源，帮助你快速落地并稳定运行。'
  : 'ai openclaw is the practical guide for setup, skills, automation, security, and operations. Learn ai openclaw in 7 days with curated ai openclaw tutorials and real ai openclaw resources.';
const canonicalUrl = isZh ? 'https://aiopenclaw.app/?lang=zh' : 'https://aiopenclaw.app/';
const schemaData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      name: 'awesome openclaw',
      url: 'https://aiopenclaw.app/',
      sameAs: ['https://x.com/JsonChao', 'https://github.com/JsonChao/'],
      contactPoint: {
        '@type': 'ContactPoint',
        contactType: 'customer support',
        email: 'support@aiopenclaw.app',
      },
    },
    {
      '@type': 'WebSite',
      name: 'awesome openclaw',
      url: 'https://aiopenclaw.app/',
      publisher: { '@type': 'Organization', name: 'awesome openclaw' },
    },
    {
      '@type': 'WebPage',
      name: pageTitle,
      url: canonicalUrl,
      description: pageDescription,
      isPartOf: { '@type': 'WebSite', name: 'awesome openclaw', url: 'https://aiopenclaw.app/' },
      publisher: { '@type': 'Organization', name: 'awesome openclaw' },
    },
  ],
};
---

<html class="dark" lang={isZh ? 'zh-CN' : 'en'}><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<script async src="https://www.googletagmanager.com/gtag/js?id=G-LZW11JCYRP"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-LZW11JCYRP');
</script>
<script type="text/javascript" is:inline>
  (function(c,l,a,r,i,t,y){
      c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
      t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
      y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
  })(window, document, "clarity", "script", "vtl8drghnb");
</script>
<title>{pageTitle}</title>
<meta name="description" content={pageDescription}/>
<link rel="icon" type="image/png" href="/images/ai-openclaw-logo.png"/>
<link rel="apple-touch-icon" href="/images/ai-openclaw-logo.png"/>
<link rel="canonical" href={canonicalUrl}/>
<meta property="og:type" content="website"/>
<meta property="og:title" content={pageTitle}/>
<meta property="og:url" content={canonicalUrl}/>
<meta property="og:description" content={pageDescription}/>
<meta property="og:image" content="https://aiopenclaw.app/images/ai-openclaw-logo.png"/>
<meta name="twitter:card" content="summary_large_image"/>
<meta name="twitter:site" content="@JsonChao"/>
<meta name="twitter:title" content={pageTitle}/>
<meta name="twitter:description" content={pageDescription}/>
<meta name="twitter:image" content="https://aiopenclaw.app/images/ai-openclaw-logo.png"/>
<script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
<link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700;800;900&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<style>
        .glow-border {
            position: relative;
            background: #ffffff;
            border: 1px solid #dbe2ee;
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
        }
        .glow-border:hover {
            border-color: rgba(59, 130, 246, 0.45);
            box-shadow: 0 12px 28px rgba(59, 130, 246, 0.16);
        }
        .grid-bg {
            background-image: linear-gradient(rgba(59, 130, 246, 0.05) 1px, transparent 1px),
                              linear-gradient(90deg, rgba(59, 130, 246, 0.05) 1px, transparent 1px);
            background-size: 40px 40px;
        }
        .text-gradient {
            background: linear-gradient(to right, #3b82f6, #a855f7, #ec5b13);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .hero-100 {
            min-height: 100svh;
            overflow: hidden;
            position: relative;
            border-bottom: 1px solid rgba(66, 107, 176, 0.4);
            background:
              radial-gradient(760px 520px at 78% 18%, rgba(93, 125, 255, 0.42), transparent 70%),
              radial-gradient(620px 520px at 88% 75%, rgba(29, 190, 177, 0.2), transparent 70%),
              linear-gradient(125deg, #071634 0%, #0a234f 45%, #0d2f66 76%, #0a2554 100%);
            box-shadow: inset 0 -80px 140px rgba(3, 10, 26, 0.5);
        }
        .hero-100::before {
            content: "";
            position: absolute;
            inset: 0;
            background:
              radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.15) 0 1px, transparent 1px),
              linear-gradient(0deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.03)),
              repeating-linear-gradient(150deg, transparent 0 18px, rgba(119, 163, 255, 0.08) 18px 19px);
            background-size: 180px 180px, auto, auto;
            opacity: 0.45;
            pointer-events: none;
        }
        :global(.hero-100-top) {
            height: 74px;
            border-bottom: 1px solid rgba(151, 189, 255, 0.24);
            background: linear-gradient(180deg, rgba(14, 38, 82, 0.8), rgba(9, 25, 56, 0.56));
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 22px;
            position: relative;
            z-index: 2;
        }
        :global(.hero-100-brand) {
            font-size: 1.85rem;
            font-weight: 800;
            color: #f5fbff;
        }
        :global(.hero-100-nav) {
            display: flex;
            gap: 2rem;
            color: #eef5ff;
            font-size: 1.05rem;
            font-weight: 600;
        }
        :global(.hero-100-nav a) { color: inherit; text-decoration: none; }
        :global(.hero-100-nav .active) {
            color: #fff;
            border-bottom: 2px solid #fff;
            padding-bottom: 10px;
        }
        :global(.hero-100-gh) {
            width: 44px;
            height: 44px;
            border-radius: 9999px;
            border: 1px solid rgba(206, 230, 255, 0.88);
            box-shadow: 0 0 18px rgba(157, 205, 255, 0.75);
            display: grid;
            place-items: center;
            font-size: 1.25rem;
            background: rgba(255,255,255,0.08);
        }
        .hero-100-main {
            width: 100%;
            max-width: 900px;
            margin: 0 auto;
            min-height: calc(100svh - 74px);
            padding: 8vh 18px 7vh;
            text-align: center;
            position: relative;
            z-index: 2;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        .hero-badge {
            width: fit-content;
            margin: 0 auto 24px;
            border-radius: 9999px;
            border: 1px solid rgba(164, 198, 255, 0.3);
            background: rgba(21, 44, 91, 0.52);
            color: #d5e8ff;
            font-size: 0.9rem;
            font-weight: 600;
            padding: 8px 14px;
        }
        .hero-100-main h1 {
            margin: 0;
            font-size: clamp(3.3rem, 8vw, 6.2rem);
            line-height: 1.02;
            color: #f7fbff;
            font-weight: 800;
        }
        .hero-100-main h1 .accent {
            background: linear-gradient(90deg, #2b8cff, #20d1c1);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .hero-zh {
            margin: 16px 0 10px;
            color: #e9f3ff;
            font-size: clamp(1.45rem, 2.45vw, 2.15rem);
            font-weight: 700;
        }
        .hero-en {
            margin: 0;
            color: #9eb2cd;
            font-size: clamp(1.05rem, 1.4vw, 1.45rem);
        }
        .hero-100-btns {
            display: flex;
            justify-content: center;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 28px;
        }
        .hero-100-btns a {
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 1.1rem;
            padding: 12px 26px;
            text-decoration: none;
            min-height: 54px;
            border: 1px solid rgba(145, 181, 230, 0.3);
            color: #eaf3ff;
            background: rgba(14, 36, 75, 0.4);
        }
        .hero-100-btns .primary {
            background: linear-gradient(145deg, #2f7bff, #2761de);
            border-color: rgba(127, 165, 255, 0.8);
            color: #fff;
            box-shadow: 0 10px 30px rgba(45, 108, 255, 0.34);
        }
        .hero-100-stats {
            margin: 64px auto 0;
            width: min(760px, 94%);
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            position: relative;
            z-index: 2;
        }
        .hero-100-stats > div {
            text-align: center;
            border-right: 1px solid rgba(146, 181, 232, 0.3);
        }
        .hero-100-stats > div:last-child { border-right: 0; }
        .hero-100-stats b {
            display: block;
            color: #f3f8ff;
            font-size: clamp(2rem, 3.2vw, 3rem);
            line-height: 1;
            font-weight: 800;
        }
        .hero-100-stats em {
            display: block;
            color: #8ca2bf;
            font-style: normal;
            font-size: 1rem;
            margin-top: 6px;
        }
        .hero-down {
            margin-top: 36px;
            color: #8da4c1;
            font-size: 2rem;
            line-height: 1;
        }
        @media (max-width: 900px) {
            :global(.hero-100-top) {
                height: auto;
                padding: 10px 14px;
                display: grid;
                grid-template-columns: 1fr auto;
                align-items: center;
                row-gap: 10px;
            }
            :global(.hero-100-brand) {
                font-size: 1.35rem;
                line-height: 1.1;
            }
            :global(.hero-100-nav) {
                grid-column: 1 / -1;
                gap: 1rem;
                font-size: 0.95rem;
                overflow-x: auto;
                white-space: nowrap;
                scrollbar-width: none;
                padding-bottom: 2px;
            }
            :global(.hero-100-nav::-webkit-scrollbar) { display: none; }
            :global(.hero-100-gh) {
                width: 36px;
                height: 36px;
                font-size: 1rem;
            }
            .hero-100-main { padding-top: 6vh; }
            .hero-100-stats {
                grid-template-columns: repeat(2, minmax(0, 1fr));
                row-gap: 16px;
                margin-top: 34px;
            }
            .hero-100-stats > div:nth-child(2) { border-right: 0; }
        }
    </style>
</head>
<body class="bg-[#d9dde6] font-display text-slate-900 overflow-x-hidden">
<main class="relative">
<!-- Grid Background Decor -->
<!-- Hero Section -->
<section class="relative w-full p-0">
  <div class="hero-100">
    <SiteHeader />
    <div class="hero-100-main">
      <div class="hero-badge">{isZh ? '🟢 开源免费 · 收录 999+ 篇教程资源' : '🟢 Open Source · 999+ ai openclaw tutorials'}</div>
      <h1>awesome <span class="accent">openclaw</span></h1>
      <div class="hero-zh">{isZh ? '从零开始，7天掌握你的 AI 私人助理' : 'Build your ai openclaw assistant in 7 days'}</div>
      <p class="hero-en">{isZh ? 'The open-source guide to building your AI assistant with OpenClaw' : 'The practical ai openclaw guide for setup, skills, workflows, and secure operation.'}</p>
      <div class="hero-100-btns">
        <a class="primary" href="#learning-path">{isZh ? '🚀 开始学习' : '🚀 Start Learning'}</a>
        <a href="#resources">{isZh ? '📚 浏览资源' : '📚 Browse Resources'}</a>
        <a href="https://github.com/JsonChao/awesome-openclaw">🐙 GitHub</a>
      </div>
      <div class="hero-100-stats">
        <div><b>999+</b><em>{isZh ? '教程收录' : 'Tutorials'}</em></div>
        <div><b>7</b><em>{isZh ? '学习路径' : 'Day Path'}</em></div>
        <div><b>300+</b><em>GitHub Stars</em></div>
        <div><b>100%</b><em>{isZh ? '开源免费' : 'Open Source'}</em></div>
      </div>
      <div class="hero-down">↓</div>
    </div>
  </div>
</section>
<!-- 什么是 OpenClaw -->
<section class="relative max-w-[1240px] mx-auto px-6 py-16">
  <h2 class="text-4xl font-extrabold text-center text-slate-900 mb-10">{isZh ? '什么是 OpenClaw？' : 'What is ai openclaw?'}</h2>
  <div class="grid md:grid-cols-3 gap-6">
    <article class="glow-border rounded-2xl p-7">
      <div class="text-4xl mb-4">🧠</div>
      <h3 class="text-xl font-bold mb-3">{isZh ? '全平台接入' : 'Multi-Channel Access'}</h3>
      <p class="text-slate-600 leading-relaxed">{isZh ? 'Telegram、Discord、WhatsApp、Signal 等多平台无缝连接，随时随地与你的 AI 助理对话。' : 'Connect ai openclaw to Telegram, Discord, WhatsApp, and more to run one assistant across channels.'}</p>
    </article>
    <article class="glow-border rounded-2xl p-7">
      <div class="text-4xl mb-4">⚡</div>
      <h3 class="text-xl font-bold mb-3">{isZh ? '技能扩展' : 'Extensible Skills'}</h3>
      <p class="text-slate-600 leading-relaxed">{isZh ? '5494+ 社区技能，从天气查询到代码生成，一键安装即用，持续提升你的效率上限。' : 'Install community skills to expand ai openclaw from daily productivity to coding and research workflows.'}</p>
    </article>
    <article class="glow-border rounded-2xl p-7">
      <div class="text-4xl mb-4">🔒</div>
      <h3 class="text-xl font-bold mb-3">{isZh ? '数据自主' : 'Data Ownership'}</h3>
      <p class="text-slate-600 leading-relaxed">{isZh ? '完全自托管，数据存储在你自己的服务器，隐私可控、安全边界清晰、长期可运营。' : 'Run ai openclaw in your own environment with clear security boundaries and long-term operational control.'}</p>
    </article>
  </div>
  <div class="mt-10 grid md:grid-cols-3 gap-6">
    <div class="overflow-hidden rounded-2xl border border-slate-200 shadow-sm">
      <img src="/images/unsplash-abstract.jpg" alt="Abstract tech background" class="w-full h-56 object-cover" loading="lazy" />
    </div>
    <div class="overflow-hidden rounded-2xl border border-slate-200 shadow-sm">
      <img src="/images/unsplash-workspace.jpg" alt="AI workspace setup" class="w-full h-56 object-cover" loading="lazy" />
    </div>
    <div class="overflow-hidden rounded-2xl border border-slate-200 shadow-sm">
      <img src="/images/unsplash-community.jpg" alt="Community collaboration" class="w-full h-56 object-cover" loading="lazy" />
    </div>
  </div>
</section>

<!-- 7天学习路径 -->
<section id="learning-path" class="bg-[#f8fafc] border-y border-slate-200 py-16">
  <div class="max-w-[1240px] mx-auto px-6">
    <h2 class="text-4xl font-extrabold text-center text-slate-900 mb-4">{isZh ? '7天学习路径' : '7-Day ai openclaw Learning Path'}</h2>
    <p class="text-center text-slate-600 mb-10">{isZh ? '从入门到进阶，每天一个主题，循序渐进掌握 OpenClaw 的核心能力。' : 'Go from setup to production in seven steps and master ai openclaw with hands-on practice.'}</p>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      <a class="glow-border rounded-xl p-5 block hover:-translate-y-0.5 transition" href="/day/1/"><div class="text-sm text-slate-500">DAY 1</div><h3 class="text-lg font-bold mt-1">{isZh ? '👋 初识 OpenClaw' : '👋 Meet ai openclaw'}</h3><p class="text-sm text-slate-600 mt-2">{isZh ? '了解 AI 私人助理的真正含义，以及 OpenClaw 能为你做什么。' : 'Understand what ai openclaw does and how to scope your first assistant project.'}</p><span class="text-sm text-orange-500 font-semibold mt-3 inline-block">{isZh ? '查看详情 →' : 'Read more →'}</span></a>
      <a class="glow-border rounded-xl p-5 block hover:-translate-y-0.5 transition" href="/day/2/"><div class="text-sm text-slate-500">DAY 2</div><h3 class="text-lg font-bold mt-1">{isZh ? '💬 深入对话' : '💬 Prompting & Dialogue'}</h3><p class="text-sm text-slate-600 mt-2">{isZh ? '掌握与 AI 助理对话的技巧，让沟通更高效、更自然。' : 'Learn prompt patterns that make ai openclaw responses precise, structured, and actionable.'}</p><span class="text-sm text-orange-500 font-semibold mt-3 inline-block">{isZh ? '查看详情 →' : 'Read more →'}</span></a>
      <a class="glow-border rounded-xl p-5 block hover:-translate-y-0.5 transition" href="/day/3/"><div class="text-sm text-slate-500">DAY 3</div><h3 class="text-lg font-bold mt-1">{isZh ? '📁 文件与代码' : '📁 Files & Code'}</h3><p class="text-sm text-slate-600 mt-2">{isZh ? '让 AI 助理帮你处理文件、写代码、执行脚本。' : 'Use ai openclaw for document processing, coding tasks, and command execution.'}</p><span class="text-sm text-orange-500 font-semibold mt-3 inline-block">{isZh ? '查看详情 →' : 'Read more →'}</span></a>
      <a class="glow-border rounded-xl p-5 block hover:-translate-y-0.5 transition" href="/day/4/"><div class="text-sm text-slate-500">DAY 4</div><h3 class="text-lg font-bold mt-1">{isZh ? '🌐 网络能力' : '🌐 Internet Tools'}</h3><p class="text-sm text-slate-600 mt-2">{isZh ? '搜索、抓取、API 调用，让 AI 助理连接互联网。' : 'Connect ai openclaw to search, scraping, and APIs for real-time web workflows.'}</p><span class="text-sm text-orange-500 font-semibold mt-3 inline-block">{isZh ? '查看详情 →' : 'Read more →'}</span></a>
      <a class="glow-border rounded-xl p-5 block hover:-translate-y-0.5 transition" href="/day/5/"><div class="text-sm text-slate-500">DAY 5</div><h3 class="text-lg font-bold mt-1">{isZh ? '🧩 技能扩展' : '🧩 Skill Extensions'}</h3><p class="text-sm text-slate-600 mt-2">{isZh ? '安装社区技能，让 AI 助理学会更多能力。' : 'Install trusted skill packs to expand ai openclaw for business, media, and operations.'}</p><span class="text-sm text-orange-500 font-semibold mt-3 inline-block">{isZh ? '查看详情 →' : 'Read more →'}</span></a>
      <a class="glow-border rounded-xl p-5 block hover:-translate-y-0.5 transition" href="/day/6/"><div class="text-sm text-slate-500">DAY 6</div><h3 class="text-lg font-bold mt-1">{isZh ? '⏰ 自动化' : '⏰ Automation'}</h3><p class="text-sm text-slate-600 mt-2">{isZh ? '定时任务、心跳检测、主动推送，让系统自主工作。' : 'Build scheduled jobs and proactive routines so ai openclaw can run tasks autonomously.'}</p><span class="text-sm text-orange-500 font-semibold mt-3 inline-block">{isZh ? '查看详情 →' : 'Read more →'}</span></a>
      <a class="glow-border rounded-xl p-5 block hover:-translate-y-0.5 transition" href="/day/7/"><div class="text-sm text-slate-500">DAY 7</div><h3 class="text-lg font-bold mt-1">{isZh ? '🔒 安全与运营' : '🔒 Security & Operations'}</h3><p class="text-sm text-slate-600 mt-2">{isZh ? '权限隔离、升级回滚与长期运维，完成生产化收尾。' : 'Harden ai openclaw with access control, upgrades, rollback, and daily operations.'}</p><span class="text-sm text-orange-500 font-semibold mt-3 inline-block">{isZh ? '查看详情 →' : 'Read more →'}</span></a>
    </div>
  </div>
</section>

<!-- 全网优质资源聚合 -->
<section id="resources" class="max-w-6xl mx-auto px-4 py-16" style="height: auto !important;">
  <div class="text-center mb-6 reveal visible">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-100 text-blue-700 text-sm font-medium mb-4">{isZh ? '📚 精选收录' : '📚 Curated Picks'}</div>
    <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">{isZh ? '全网优质资源聚合' : 'Curated ai openclaw Resources'}</h2>
    <p class="text-lg text-gray-600 max-w-2xl mx-auto">{isZh ? '从阿里云、腾讯云到 DigitalOcean，从 B站到 Codecademy —— 一站式获取 OpenClaw 最佳教程。' : 'From cloud deployment docs to videos and deep dives, find practical ai openclaw resources in one place.'}</p>
  </div>
  <div class="reveal mb-8 mx-auto max-w-3xl visible">
    <div class="flex items-start gap-3 px-4 py-3 rounded-xl bg-amber-50 border border-amber-200 text-amber-800 text-sm">
      <span class="text-lg mt-0.5">⚠️</span>
      <div>
        <span class="font-semibold">{isZh ? '安全提醒：' : 'Security Notice:'}</span>{isZh ? '近期发现有恶意 Skills 通过 ClawHub 分发，窃取用户数据。安装第三方 Skill 前请务必检查源码，优先使用官方或社区审核的 Skills。' : 'Malicious skills were reported in public marketplaces. Review source code before installing third-party ai openclaw skills.'}
        <a href="https://thehackernews.com/2026/02/researchers-find-341-malicious-clawhub.html" target="_blank" rel="noopener noreferrer" class="ml-1 text-amber-700 underline hover:text-amber-900">{isZh ? '详情 ↗' : 'Details ↗'}</a>
      </div>
    </div>
