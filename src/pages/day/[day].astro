---
import '../../styles/tailwind.css';
import '../../styles/custom.css';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';

type Step = { title: string; detail: string; command?: string; verify: string };
type Timeline = { time: string; event: string; value: string };
type Faq = { q: string; a: string };
type Narrative = { quote: string; storyTitle: string; story: string[]; dialogue: string[]; reflection: string };
type StoryChapter = { title: string; paragraphs: string[] };
type KnowledgeCard = { term: string; explanation: string; whyItMatters: string };

type DayPlan = {
  day: number;
  title: string;
  subtitle: string;
  goal: string;
  duration: string;
  intro: string[];
  chapterOverview: string[];
  concepts: { title: string; text: string }[];
  timeline: Timeline[];
  steps: Step[];
  deliverables: string[];
  pitfalls: string[];
  checklist: string[];
  promptTemplate: string;
  faq: Faq[];
  preview: string;
  references: { name: string; url: string }[];
};

const dayPlans: DayPlan[] = [
  {
    day: 1,
    title: '认识 OpenClaw：从聊天到执行',
    subtitle: '搞清楚 AI 助手与聊天机器人本质差异，建立正确起点。',
