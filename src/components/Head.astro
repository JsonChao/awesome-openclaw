---
const starlightRoute = (Astro.locals as any).starlightRoute ?? { head: [], title: '', description: '' };
const { head, title, description } = starlightRoute;
const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://aiopenclaw.app';
const path = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const url = `${site}${path}`;
const isHome = path === '/';
const pageTitle = title ?? 'awesome openclaw';
const pageDescription = description ?? 'awesome openclaw 是面向 ai openclaw 的中文教程与资源站。';
const org = {
  '@type': 'Organization',
  name: 'awesome openclaw',
  url: site,
  sameAs: ['https://x.com/JsonChao', 'https://github.com/JsonChao/'],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    email: 'support@aiopenclaw.app',
  },
};
const webSite = {
  '@type': 'WebSite',
  name: 'awesome openclaw',
  url: site + '/',
  publisher: org,
};
const webPage = {
  '@type': 'WebPage',
  name: pageTitle,
  url,
  description: pageDescription,
  isPartOf: webSite,
  publisher: org,
};
const breadcrumb = isHome
  ? null
  : {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: '首页',
          item: site + '/',
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: pageTitle,
          item: url,
        },
      ],
    };
const jsonLd = [webSite, org, webPage, ...(breadcrumb ? [breadcrumb] : [])];
---

<script async src="https://www.googletagmanager.com/gtag/js?id=G-LZW11JCYRP"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-LZW11JCYRP');
</script>
<script type="text/javascript" is:inline>
  (function(c,l,a,r,i,t,y){
      c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
      t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
      y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
  })(window, document, "clarity", "script", "vtl8drghnb");
</script>
<meta property="og:type" content="website" />
<meta property="og:title" content={pageTitle} />
<meta property="og:url" content={url} />
<meta property="og:description" content={pageDescription} />
<meta property="og:image" content="https://aiopenclaw.app/images/ai-openclaw-logo.png" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@JsonChao" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={pageDescription} />
<meta name="twitter:image" content="https://aiopenclaw.app/images/ai-openclaw-logo.png" />
{head.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}
<script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)}></script>
